# Postgres (matches docker-compose service)
DATABASE_URL="postgresql://lomicode:lomicode@localhost:5432/lomicode_admin?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# MinIO / S3-compatible release storage
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="lomicode"
S3_SECRET_KEY="lomicode-secret"
S3_BUCKET="releases"
S3_FORCE_PATH_STYLE="true"

# Subscription grace period in days (banner -> read-only after this)
SUBSCRIPTION_GRACE_DAYS="7"

# First vendor admin (used by `npm run seed` only)
SEED_VENDOR_EMAIL="admin@lomicode.local"
SEED_VENDOR_PASSWORD="ChangeMe!2026"
SEED_VENDOR_NAME="LomiCode Admin"
