# LomiCode Vendor Admin — production environment.
#
# EVERY VARIABLE IS OPTIONAL. The compose file ships with safe defaults so
# `docker compose up -d --build` works with no configuration. Override any
# of these (via Hostinger's Environment tab, an .env file, or your CI) to
# harden the install for real-world use.
#
# Recommended for any internet-facing deploy:
#   • Set DOMAIN + ADMIN_EMAIL → flips Caddy into auto-HTTPS
#   • Replace POSTGRES_PASSWORD + S3 keys → no shared default secrets
#   • Override SEED_VENDOR_PASSWORD before first boot, OR sign in once
#     with the default and change it from /account immediately
#
#   cp .env.production.example .env.production
#   # …edit…
#   docker compose --env-file .env.production up -d --build

# ─── Public URL ────────────────────────────────────────────────────────
# Leave unset to serve plain HTTP on port 80 (good for first test). Set
# to your real domain — DNS A record must already point at this VPS —
# to enable Caddy's automatic Let's Encrypt cert. The entrypoint
# auto-rewrites NEXTAUTH_URL to https://$DOMAIN when DOMAIN is set, so
# you usually don't need to touch NEXTAUTH_URL by hand.
#DOMAIN=admin.example.com
#ADMIN_EMAIL=ops@example.com
#NEXTAUTH_URL=https://admin.example.com

# ─── NextAuth secret ──────────────────────────────────────────────────
# Auto-generated on first boot if unset, then persisted to a Docker
# volume so it survives restarts. Override only if you want to inject
# your own (e.g. via your secret manager).
#   openssl rand -base64 48
#NEXTAUTH_SECRET=

# ─── Postgres ─────────────────────────────────────────────────────────
#POSTGRES_DB=lomicode_admin
#POSTGRES_USER=lomicode
#POSTGRES_PASSWORD=lomicode-change-me

# ─── MinIO / S3 release storage ───────────────────────────────────────
#S3_ENDPOINT=http://minio:9000
#S3_REGION=us-east-1
#S3_ACCESS_KEY=lomicode
#S3_SECRET_KEY=lomicode-change-me
#S3_BUCKET=releases

# ─── Subscription policy ──────────────────────────────────────────────
#SUBSCRIPTION_GRACE_DAYS=7

# ─── First-boot vendor admin ──────────────────────────────────────────
# Created by the entrypoint on the very first container start when the
# users table is empty. Override before first boot, OR sign in once with
# the defaults and change the password from /account.
#SEED_VENDOR_EMAIL=admin@lomicode.local
#SEED_VENDOR_PASSWORD=ChangeMe!2026
#SEED_VENDOR_NAME=LomiCode Admin
