# LomiCode Vendor Admin — production environment.
#
# Copy to `.env.production` on your VPS, fill in real values, and keep it
# out of git (`.env*` is already in .dockerignore + .gitignore).
#
#   cp .env.production.example .env.production
#   # …edit…
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# ─── Public URL ────────────────────────────────────────────────────────
# The HTTPS domain users will visit. Caddy provisions a Let's Encrypt cert
# for this domain automatically — make sure the DNS A record points here
# BEFORE you start the stack, or the cert request fails.
DOMAIN="admin.example.com"
NEXTAUTH_URL="https://admin.example.com"

# Email Caddy registers with Let's Encrypt for cert expiry warnings.
ADMIN_EMAIL="ops@example.com"

# ─── NextAuth secret ──────────────────────────────────────────────────
# Generate with:  openssl rand -base64 48
NEXTAUTH_SECRET="REPLACE_WITH_LONG_RANDOM_STRING"

# ─── Postgres ─────────────────────────────────────────────────────────
# Picked up by the `postgres` service AND assembled into DATABASE_URL for
# the app — keep them aligned.
POSTGRES_DB="lomicode_admin"
POSTGRES_USER="lomicode"
POSTGRES_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"

# ─── MinIO / S3 release storage ───────────────────────────────────────
# Same credentials are passed to MinIO at boot AND used by the app's S3
# client. Change them from the dev defaults before going live.
S3_ENDPOINT="http://minio:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="REPLACE_WITH_ACCESS_KEY"
S3_SECRET_KEY="REPLACE_WITH_SECRET_KEY"
S3_BUCKET="releases"

# ─── Subscription policy ──────────────────────────────────────────────
SUBSCRIPTION_GRACE_DAYS="7"
